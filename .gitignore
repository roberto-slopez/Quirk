# Rust / Cargo
/target/
**/*.rs.bk

# Note: Cargo.lock is COMMITTED for this binary crate so that CI's
# `cargo test --locked` / `cargo build --locked` commands succeed and
# builds are reproducible across machines. For library crates we'd
# gitignore it instead.

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local artifacts (ignore PNGs by default; allow the README screenshot)
*.png
!/screenshot.png
!docs/**/*.png
!assets/**/*.png

# Test / coverage
coverage/
*.lcov

# Just / task runner
.justfile.local